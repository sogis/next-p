{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["tables"],
  "properties": {
    "tables": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["ident", "table", "schema_ref", "columns"],
        "properties": {
          "ident": {
            "type": "string"
          },
          "table": {
            "type": "string"
          },
          "schema_ref": {
            "type": "string"
          },
          "columns": {
            "oneOf": [
              {
                "type": "array",
                "items": {
                  "$ref": "#/$defs/column"
                }
              },
              {
                "type": "object",
                "required": ["_jinja_filepath"],
                "properties": {
                  "_jinja_filepath": {
                    "type": "string"
                  }
                },
                "additionalProperties": false
              }
            ]
          }
        },
        "additionalProperties": false
      }
    }
  },
  "$defs": {
    "column": {
      "type": "object",
      "required": ["name", "alias"],
      "properties": {
        "name": {
          "type": "string"
        },
        "alias": {
          "type": "string"
        },
        "_json_columns": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/json_column"
          }
        }
      },
      "additionalProperties": false
    },
    "json_column": {
      "type": "object",
      "required": ["name", "alias"],
      "properties": {
        "name": {
          "type": "string"
        },
        "alias": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}